{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=mallxpro;Username=mallx;Password=YOUR_DB_PASSWORD;Pooling=true;MinPoolSize=2;MaxPoolSize=20;CommandTimeout=30"
  },

  "Redis": {
    "ConnectionString": "localhost:6379",
    "Password":         "YOUR_REDIS_PASSWORD"
  },

  "Jwt": {
    "Secret":                    "YOUR_64_CHAR_SECRET_MINIMUM_FOR_HMAC_SHA256_JWT_SIGNING_KEY!!",
    "Issuer":                    "mallxpro",
    "Audience":                  "mallxpro-client",
    "ExpiryMinutes":             "60",
    "RefreshExpiryDays":         "30",
    "CustomerExpiryMinutes":     "60",
    "CustomerRefreshExpiryDays": "30"
  },

  "AllowedOrigins": [
    "http://localhost:3000",
    "http://localhost:8081",
    "https://yourdomain.com"
  ],

  "Paymob": {
    "ApiKey":        "",
    "IntegrationId": "",
    "IframeId":      "",
    "HmacSecret":    "",
    "BaseUrl":       "https://accept.paymob.com/api"
  },

  "Firebase": {
    "ServerKey":    "",
    "ProjectId":    "",
    "SenderId":     ""
  },

  "Anthropic": {
    "ApiKey":       "",
    "Model":        "claude-sonnet-4-5",
    "MaxTokens":    1024
  },

  "WhatsApp": {
    "Enabled":      "false",
    "AccountSid":   "",
    "AuthToken":    "",
    "FromNumber":   "whatsapp:+14155238886"
  },

  "Serilog": {
    "MinimumLevel": {
      "Default":    "Information",
      "Override": {
        "Microsoft":              "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System":                 "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path":                 "logs/mallx-.log",
          "rollingInterval":      "Day",
          "retainedFileCountLimit": 14,
          "outputTemplate":       "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },

  "Delivery": {
    "DefaultFeeEgp":    15,
    "FreeDeliveryAbove": 200,
    "MaxRadiusKm":       20
  },

  "Loyalty": {
    "PointsPerEgp":         1.0,
    "MaxRedeemPct":         0.20,
    "ExpiryMonths":         12,
    "SignupBonusPoints":    50,
    "RatingBonusPoints":    5
  },

  "Platform": {
    "DefaultCommissionRate": 0.05,
    "TrialDays":             14,
    "SupportEmail":          "support@mallx.app"
  },

  "CORS": {
    "AllowedHeaders":       [ "*" ],
    "AllowedMethods":       [ "GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS" ]
  }
